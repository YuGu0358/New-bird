# ===================================================================
# Newbird Quant Console — environment variables
# ===================================================================
# Required for full functionality:
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
OPENAI_API_KEY=

# Recommended:
POLYGON_API_KEY=          # extended market data, news; without it falls back to yfinance
TAVILY_API_KEY=           # news search

# Optional:
ANTHROPIC_API_KEY=        # alternative LLM provider for AI Council
SETTINGS_ADMIN_TOKEN=     # if set, /api/settings writes require X-Admin-Token header

# Deployment:
PORT=8000                                       # Railway sets this automatically
DATA_DIR=/app/data                              # persistent SQLite location (mount a volume here)
TRADING_PLATFORM_FRONTEND_DIST=/app/frontend-v2/dist
CORS_ALLOW_ORIGINS=*                            # comma-separated origin whitelist; '*' = open
FACTOR_EVOLUTION_AUTOSTART=false                # 'true' to auto-start the GP loop on boot
                                                # — leave 'false' on Railway to avoid runaway compute

# Model overrides (defaults already set to mini in code):
OPENAI_FACTOR_MODEL=gpt-4o-mini-2024-07-18      # GP variant generation
OPENAI_QA_MODEL=gpt-4o-mini-2024-07-18          # Q&A NL search
OPENAI_NEWS_MODEL=gpt-4o-mini-2024-07-18
OPENAI_CANDIDATE_MODEL=gpt-4o-2024-08-06        # candidate selection (kept on bigger model)
OPENAI_CHART_MODEL=gpt-4o-2024-08-06            # vision-based chart annotation
