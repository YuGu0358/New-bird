<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>{{ title }}</title>
  <style>
    body {
      font-family: -apple-system, "Helvetica Neue", Arial, sans-serif;
      color: #1a1a1a;
      margin: 32px;
      line-height: 1.5;
    }
    h1 { font-size: 22pt; margin-bottom: 4px; }
    h2 { font-size: 14pt; margin-top: 24px; border-bottom: 1px solid #e0e0e0; padding-bottom: 4px; }
    .meta { color: #666; font-size: 9pt; margin-bottom: 24px; }
    table { width: 100%; border-collapse: collapse; margin-top: 8px; font-size: 10pt; }
    th, td { text-align: left; padding: 6px 10px; border-bottom: 1px solid #ececec; }
    th { background: #fafafa; font-weight: 600; }
    .num { text-align: right; font-variant-numeric: tabular-nums; }
    .pos { color: #1a8b3a; }
    .neg { color: #c0392b; }
    .pill { display: inline-block; padding: 2px 8px; border-radius: 12px; background: #f0f0f0; font-size: 8pt; }
    @media print {
      body { margin: 12mm; }
      h2 { break-inside: avoid; }
      table { break-inside: avoid; }
    }
  </style>
</head>
<body>
  <h1>{{ title }}</h1>
  <div class="meta">Generated {{ generated_at | fmt_dt }}</div>
  {% block body %}{% endblock %}
</body>
</html>
